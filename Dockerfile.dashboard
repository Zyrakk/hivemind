# Optional image for option (B): static dashboard served by nginx.
# Default deployment uses option (A), where frontend is embedded in orchestrator binary.

FROM node:20-alpine AS builder
WORKDIR /app

COPY dashboard/package.json dashboard/package-lock.json ./
RUN npm ci

COPY dashboard/ ./
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
