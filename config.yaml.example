glm:
  api_key_env: ZAI_API_KEY
  model: glm-4.7
  base_url: https://api.z.ai/v1
  max_retries: 3
  timeout: 60s

engine:
  primary: "glm"               # "claude-code" or "glm"
  fallback: "none"             # "glm", "claude-code", or "none"
  claude_code:
    binary: "claude"
    model: ""                  # empty = CLI default from Max plan
    timeout_minutes: 10
    prompt_dir: "prompts"
    usage:                     # Max 5x quota management (shared with claude.ai web)
      soft_limit_daily: 12     # Telegram alert at this threshold
      hard_limit_daily: 18     # stop + fallback to GLM
      soft_limit_weekly: 70    # weekly alert threshold
      hard_limit_weekly: 100   # weekly stop + fallback

consultants:
  claude:
    enabled: false
    api_key_env: ANTHROPIC_API_KEY
    model: claude-sonnet-4-5
    max_monthly_budget_usd: 100.0
    max_calls_per_day: 50
    use_for:
      - architecture_review
      - risk_assessment
  gemini:
    enabled: false
    api_key_env: GEMINI_API_KEY
    model: gemini-2.5-pro
    max_calls_per_day: 50
    use_for:
      - test_strategy
      - edge_case_analysis

codex:
  approval_mode: auto
  default_model: gpt-5-codex
  timeout_minutes: 30
  workers_dir: /tmp/hivemind-workers

telegram:
  bot_token_env: TELEGRAM_BOT_TOKEN
  allowed_chat_id: 0

dashboard:
  port: 8080
  host: 0.0.0.0

database:
  path: ./hivemind.db

git:
  default_remote: origin
  branch_prefix: hivemind/
