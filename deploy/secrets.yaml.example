# Hivemind Secrets
# ================
# Copy to deploy/secrets.yaml, fill in real values, apply once.
# NEVER commit deploy/secrets.yaml to Git.
#
# Apply:
#   kubectl apply -f deploy/secrets.yaml
#
# For codex-auth, copy your local auth.json:
#   kubectl -n hivemind create secret generic codex-auth \
#     --from-file=auth.json=$HOME/.codex/auth.json \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# For claude-code-auth, see deploy/claude-code-secret.yaml.example
---
apiVersion: v1
kind: Secret
metadata:
  name: hivemind-secrets
  namespace: hivemind
type: Opaque
stringData:
  ZAI_API_KEY: "REPLACE"
  ANTHROPIC_API_KEY: ""           # leave empty if consultants.claude.enabled = false
  GOOGLE_AI_API_KEY: ""           # leave empty if consultants.gemini.enabled = false
  TELEGRAM_BOT_TOKEN: "REPLACE"
