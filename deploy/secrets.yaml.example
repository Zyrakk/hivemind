# Copy this file to deploy/secrets.yaml and replace placeholder values.
# Do NOT commit deploy/secrets.yaml with real secrets.
apiVersion: v1
kind: Secret
metadata:
  name: hivemind-secrets
  namespace: hivemind
type: Opaque
stringData:
  ZAI_API_KEY: "replace-me"
  ANTHROPIC_API_KEY: "replace-me"
  GOOGLE_AI_API_KEY: "replace-me"
  TELEGRAM_BOT_TOKEN: "replace-me"
---
# codex-auth must contain the auth.json file copied from ~/.codex/auth.json on your host.
# Create it with:
# kubectl -n hivemind create secret generic codex-auth --from-file=auth.json=$HOME/.codex/auth.json
# If refresh_token expires, update it with:
# kubectl -n hivemind create secret generic codex-auth --from-file=auth.json=$HOME/.codex/auth.json --dry-run=client -o yaml | kubectl apply -f -
apiVersion: v1
kind: Secret
metadata:
  name: codex-auth
  namespace: hivemind
type: Opaque
stringData:
  auth.json: |
    {
      "OPENAI_API_KEY": "replace-me",
      "refresh_token": "replace-me"
    }

# Apply order example:
# kubectl --kubeconfig /home/stefan/.zcloud/kubeconfig apply -f deploy/orchestrator.yaml
# kubectl --kubeconfig /home/stefan/.zcloud/kubeconfig apply -f deploy/secrets.yaml
